<?xml version="1.0" encoding="utf-8"?>
<package xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <metadata>
    <id>docker-scout-cli</id>
    <title>Docker Scout CLI</title>
    <version>1.20.0</version>
    <authors>Docker Inc.</authors>
    <owners>BlythMeister</owners>
    <summary>Installs the Docker Scout CLI plugin for a target Windows user profile</summary>
    <description><![CDATA[Installs the Docker Scout CLI plugin for Windows and configures Docker CLI plugin discovery for a specific user profile.

The package downloads the official Docker Scout Windows x64 release, installs `docker-scout.exe` into the target profile's `.docker\scout` directory, and updates `.docker\config.json` to include that directory in `cliPluginsExtraDirs`.

You must provide either `/UserProfileName=<name>` or `/UserProfilePath=<path>` as package parameters so the plugin is installed into the correct user profile for your build agent or service account.
]]></description>
    <projectUrl>https://github.com/docker/scout-cli</projectUrl>
    <packageSourceUrl>https://github.com/BlythMeister/chocolatey-packages/tree/master/automatic/docker-scout-cli</packageSourceUrl>
    <docsUrl>https://docs.docker.com/scout/install/</docsUrl>
    <releaseNotes>https://github.com/docker/scout-cli/releases</releaseNotes>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <tags>docker scout cli sbom security plugin build-agent</tags>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
  </files>
</package>
