<?xml version="1.0" encoding="utf-8"?>
<package xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <metadata>
    <id>docker-scout-cli</id>
    <title>Docker Scout CLI</title>
    <version>1.20.3</version>
    <authors>Docker Inc.</authors>
    <owners>BlythMeister</owners>
    <summary>Installs the Docker Scout CLI plugin for Windows</summary>
    <description><![CDATA[Installs the Docker Scout CLI plugin for Windows using Docker's documented manual installation layout.

The package downloads the official Docker Scout Windows x64 release, installs `docker-scout.exe` into `%USERPROFILE%\.docker\scout` by default, and updates `%USERPROFILE%\.docker\config.json` so Docker discovers the plugin through `cliPluginsExtraDirs`.

Docker CLI must already be installed separately.

You can override the plugin directory with the optional `/PluginDirectory=<path>` package parameter. The package will add that absolute path to Docker's `cliPluginsExtraDirs` setting during installation.
]]></description>
    <licenseUrl>https://www.docker.com/legal/docker-subscription-service-agreement/</licenseUrl>
    <projectUrl>https://github.com/docker/scout-cli</projectUrl>
    <packageSourceUrl>https://github.com/BlythMeister/chocolatey-packages/tree/master/automatic/docker-scout-cli</packageSourceUrl>
    <docsUrl>https://docs.docker.com/scout/install/</docsUrl>
    <iconUrl>https://raw.githubusercontent.com/BlythMeister/chocolatey-packages/master/icons/docker.png</iconUrl>
    <releaseNotes>https://github.com/docker/scout-cli/releases</releaseNotes>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <tags>docker scout cli sbom security plugin build-agent user-profile</tags>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
  </files>
</package>
