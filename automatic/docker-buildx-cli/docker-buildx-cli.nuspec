<?xml version="1.0" encoding="utf-8"?>
<package xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <metadata>
    <id>docker-buildx-cli</id>
    <title>Docker Buildx CLI</title>
    <version>0.33.0</version>
    <authors>Docker Inc.</authors>
    <owners>BlythMeister</owners>
    <summary>Installs the Docker Buildx CLI plugin for Windows</summary>
    <description><![CDATA[Installs the Docker Buildx CLI plugin for Windows into Docker's user-scoped CLI plugin directory so it is available to the installing user.

The package downloads the official Docker Buildx Windows x64 release and installs `docker-buildx.exe` into `%USERPROFILE%\.docker\cli-plugins` by default, matching Docker's documented manual installation instructions for Windows.

Docker CLI must already be installed separately.

You can override the plugin directory with the optional `/PluginDirectory=<path>` package parameter if you want to use one of Docker's alternative standard plugin directories such as `C:\ProgramData\Docker\cli-plugins` or `C:\Program Files\Docker\cli-plugins`. Non-standard plugin directories must also be configured in Docker before the CLI will discover the plugin automatically.
]]></description>
    <licenseUrl>https://www.apache.org/licenses/LICENSE-2.0</licenseUrl>
    <projectUrl>https://github.com/docker/buildx</projectUrl>
    <packageSourceUrl>https://github.com/BlythMeister/chocolatey-packages/tree/master/automatic/docker-buildx-cli</packageSourceUrl>
    <iconUrl>https://raw.githubusercontent.com/BlythMeister/chocolatey-packages/master/icons/docker.png</iconUrl>
    <releaseNotes>https://github.com/docker/buildx/releases</releaseNotes>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <tags>docker buildx cli plugin build-agent user-profile</tags>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
  </files>
</package>
